{
  // Formatters
  "[blade]": {
    "editor.defaultFormatter": "shufo.vscode-blade-formatter",
    "editor.formatOnSave": true
  },
  "[css]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },
  "[html]": {
    "editor.defaultFormatter": "vscode.html-language-features",
    "editor.formatOnSave": true
  },
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[jsonl]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[markdown]": {
    "files.trimTrailingWhitespace": false
  },
  "[php]": {
    "editor.defaultFormatter": "bmewburn.vscode-intelephense-client",
    "editor.formatOnSave": true
  },
  "[scss]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },
  "[vue]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },
  // Breadcrumbs
  "breadcrumbs.enabled": false,
  // Chat
  "chat.agent.enabled": false,
  "chat.agentsControl.enabled": "hidden",
  "chat.autopilot.enabled": false,
  "chat.checkpoints.enabled": false,
  "chat.contextUsage.enabled": false,
  "chat.customizations.harnessSelector.enabled": false,
  "chat.detectParticipant.enabled": false,
  "chat.disableAIFeatures": true,
  "chat.extensionTools.enabled": false,
  "chat.extensionUnification.enabled": false,
  "chat.implicitContext.enabled": {
    "panel": "never"
  },
  "chat.math.enabled": false,
  "chat.mcp.apps.enabled": false,
  "chat.plugins.enabled": false,
  "chat.tips.enabled": false,
  "chat.tools.renameTool.enabled": false,
  "chat.tools.terminal.enableAutoApprove": false,
  "chat.tools.usagesTool.enabled": false,
  "chat.viewSessions.enabled": false,
  // Debug
  "debug.console.fontSize": 13,
  // Diff Editor
  "diffEditor.ignoreTrimWhitespace": true,
  "diffEditor.renderSideBySide": false,
  "diffEditor.wordWrap": "off",
  // Editor
  "editor.acceptSuggestionOnCommitCharacter": false,
  "editor.acceptSuggestionOnEnter": "off",
  "editor.accessibilitySupport": "off",
  "editor.allowVariableFonts": false,
  "editor.allowVariableLineHeights": false,
  "editor.autoClosingBrackets": "always",
  "editor.autoClosingComments": "always",
  "editor.autoClosingDelete": "always",
  "editor.autoClosingOvertype": "always",
  "editor.autoClosingQuotes": "always",
  "editor.autoIndent": "none",
  "editor.autoIndentOnPasteWithinString": false,
  "editor.autoSurround": "never",
  "editor.bracketPairColorization.enabled": false,
  "editor.codeActionsOnSave": {
    "source.addMissingImports.ts": "always",
    "source.fixAll.eslint": "always",
    "source.fixAll.prettier": "always",
    "source.fixAll.ts": "always",
    "source.organizeImports": "always",
    "source.removeUnused.ts": "always",
    "source.removeUnusedImports": "always",
    "source.sort.json": "always",
    "source.sortImports": "always"
  },
  "editor.codeActionWidget.includeNearbyQuickFixes": false,
  "editor.codeActionWidget.showHeaders": false,
  "editor.codeLens": false,
  "editor.codeLensFontSize": 13,
  "editor.colorDecorators": false,
  "editor.comments.ignoreEmptyLines": false,
  "editor.comments.insertSpace": false,
  "editor.copyWithSyntaxHighlighting": false,
  "editor.cursorBlinking": "solid",
  "editor.cursorStyle": "line",
  "editor.cursorWidth": 2,
  "editor.defaultColorDecorators": "never",
  "editor.detectIndentation": false,
  "editor.editContext": false,
  "editor.emptySelectionClipboard": false,
  "editor.experimentalWhitespaceRendering": "off",
  "editor.folding": false,
  "editor.foldingHighlight": false,
  "editor.fontFamily": "Menlo",
  "editor.fontLigatures": true,
  "editor.fontSize": 14,
  "editor.fontWeight": "500",
  "editor.formatOnSave": true,
  "editor.gotoLocation.multipleDeclarations": "goto",
  "editor.gotoLocation.multipleDefinitions": "goto",
  "editor.gotoLocation.multipleImplementations": "goto",
  "editor.gotoLocation.multipleReferences": "goto",
  "editor.gotoLocation.multipleTypeDefinitions": "goto",
  "editor.guides.bracketPairsHorizontal": false,
  "editor.guides.highlightActiveBracketPair": false,
  "editor.guides.highlightActiveIndentation": false,
  "editor.guides.indentation": false,
  "editor.hideCursorInOverviewRuler": true,
  "editor.hover.delay": 750,
  "editor.hover.enabled": "off",
  "editor.inlayHints.enabled": "off",
  "editor.inlineSuggest.enabled": false,
  "editor.inlineSuggest.suppressSuggestions": true,
  "editor.insertSpaces": false,
  "editor.lightbulb.enabled": "off",
  "editor.lineHeight": 22,
  "editor.linkedEditing": true,
  "editor.matchBrackets": "never",
  "editor.minimap.enabled": false,
  "editor.mouseWheelScrollSensitivity": 1.5,
  "editor.occurrencesHighlight": "off",
  "editor.overtypeCursorStyle": "line",
  "editor.overviewRulerBorder": false,
  "editor.padding.bottom": 8,
  "editor.padding.top": 8,
  "editor.parameterHints.enabled": false,
  "editor.rename.enablePreview": false,
  "editor.renderControlCharacters": false,
  "editor.renderLineHighlight": "none",
  "editor.renderWhitespace": "selection",
  "editor.roundedSelection": false,
  "editor.scrollbar.horizontal": "hidden",
  "editor.scrollbar.horizontalScrollbarSize": 0,
  "editor.scrollbar.vertical": "hidden",
  "editor.scrollbar.verticalScrollbarSize": 0,
  "editor.scrollPredominantAxis": false,
  "editor.selectionHighlight": false,
  "editor.semanticHighlighting.enabled": false,
  "editor.showFoldingControls": "never",
  "editor.snippets.codeActions.enabled": false,
  "editor.snippetSuggestions": "top",
  "editor.stickyScroll.enabled": false,
  "editor.suggest.insertMode": "replace",
  "editor.suggest.showWords": false,
  "editor.suggestFontSize": 13,
  "editor.suggestSelection": "recentlyUsed",
  "editor.tabCompletion": "on",
  "editor.tabSize": 2,
  "editor.unicodeHighlight.ambiguousCharacters": false,
  "editor.unicodeHighlight.invisibleCharacters": false,
  "editor.unusualLineTerminators": "off",
  "editor.wordWrap": "off",
  "editor.wrappingIndent": "none",
  // Emmet
  "emmet.includeLanguages": {
    "blade.php": "html",
    "twig": "html"
  },
  "emmet.triggerExpansionOnTab": true,
  // Explorer
  "explorer.autoReveal": false,
  "explorer.compactFolders": false,
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  "explorer.confirmPasteNative": false,
  "explorer.confirmUndo": "light",
  "explorer.decorations.badges": false,
  "explorer.decorations.colors": false,
  "explorer.fileNesting.patterns": {
    ".php-cs-fixer.php": ".php-cs-fixer.cache",
    "*.js": "${capture}.js.map, ${capture}.min.js, ${capture}.d.ts",
    "*.jsx": "${capture}.js",
    "*.php": "${basename}Test.php",
    "*.ts": "${capture}.js",
    "*.tsx": "${capture}.ts",
    "composer.json": "composer.lock",
    "package.json": "package-lock.json, yarn.lock, pnpm-lock.yaml, bun.lockb, bun.lock",
    "phpunit.xml": ".phpunit.result.cache",
    "psalm.xml": "psalm-baseline.xml",
    "tsconfig.json": "tsconfig.*.json"
  },
  "explorer.openEditors.visible": 8,
  "explorer.sortOrder": "type",
  // Files
  "files.exclude": {
    "**/.DS_Store": true,
    "**/.git": true,
    "**/.hg": true,
    "**/.idea": true,
    "**/.svn": true,
    "**/.vendor": true,
    "**/.vscode": true,
    "**/*.code-search": true,
    "**/bower_components": true,
    "**/node_modules": true,
    "**/Thumbs.db": true
  },
  // Terminal
  "terminal.integrated.fontFamily": "Menlo",
  "terminal.integrated.fontSize": 13,
  "terminal.integrated.fontWeight": "normal",
  "terminal.integrated.lineHeight": 1.3,
  "workbench.activityBar.location": "top",
  //workbench
  "workbench.editor.showTabs": "multiple",
  "workbench.secondarySideBar.defaultVisibility": "visible",
  "workbench.secondarySideBar.showLabels": true,
  "workbench.sideBar.location": "right"
}
